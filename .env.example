# Required for production: public URL of this app (registration & RSVP links in emails and "Copy link").
# If not set, links may be localhost when invitees click from the email.
# In Vercel: Project → Settings → Environment Variables → add VITE_APP_PUBLIC_URL = your deploy URL → redeploy.
# Example: https://eventy-dashboard-local-deployment.vercel.app
VITE_APP_PUBLIC_URL=
