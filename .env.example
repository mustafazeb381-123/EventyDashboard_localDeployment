# Required for production: public URL of this app (registration & RSVP links in emails and "Copy link").
# If not set, links may be localhost when invitees click from the email.
# In Vercel: Project → Settings → Environment Variables → add VITE_APP_PUBLIC_URL = your deploy URL → redeploy.
# Example: https://eventy-dashboard-local-deployment.vercel.app
VITE_APP_PUBLIC_URL=

# Optional: root domain for subdomain redirect (e.g. eventy.com). Used in Signup workspace preview and after-login redirect.
# VITE_APP_ROOT_DOMAIN=eventy.com

# Optional: set to true to redirect after login to https://{company}.eventy.com instead of /{company}. Requires DNS wildcard (*.eventy.com).
# VITE_APP_USE_SUBDOMAIN=false
